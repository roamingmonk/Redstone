{
    "files.exclude": {
        "**/__pycache__/": true,
        "**/.venv/": true,
        ".claude/worktrees": true
    },
    "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
    "git.autoRepositoryDetection": "openEditors",
    "git.ignoredRepositories": [
        ".claude/worktrees/blissful-panini",
        ".claude/worktrees/quirky-cohen",
        ".claude/worktrees/silly-wescoff"
    ],
    "python.terminal.activateEnvironment": true,
    "terminal.integrated.profiles.windows": {
        "Python (project venv)": {
            "source": "PowerShell",
            "args": [
                "-NoExit",
                "-Command",
                "if (Test-Path .venv\\Scripts\\Activate.ps1) { .venv\\Scripts\\Activate.ps1 }; python"
            ],
            "icon": "python"
        }
    }
}