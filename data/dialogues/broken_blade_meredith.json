{
  "id": "broken_blade_meredith",
  "npc_name": "Meredith",

  "states": {
    "first_meeting": {
      "introduction": [
        "Welcome to the Broken Blade. I am Meredith.",
        "Keep it polite and we will get along fine.",
        "*A distant rumble shakes the tavern slightly*"
      ],
      "options": [
        { "id": "ask_specials", "text": "What are todays specials?", "next_state": "specials_info" },
        { "id": "ask_tavern",   "text": "Tell me about this tavern.",  "next_state": "about_tavern" },
        {
          "id": "ask_rumors",
          "text": "Heard anything unusual lately?",
          "effects": [
            { "type": "set_flag", "flag": "meredith_gave_swamp_info", "value": true },
            { "type": "set_flag", "flag": "learned_about_swamp_church", "value": true }
        ],
          "next_state": "knows_about_swamp"
        },
        { "id": "bye_first", "text": "Just looking around. Goodbye.", "next_state": "exit" }
      ]
    },

    "about_tavern": {
      "introduction": [
        "Oldest alehouse in Redstone. Miners, hunters, and", "travelers keep us busy.",
        "If you need gear, the general store is on the square."
      ],
      "options": [
        { "id": "back", "text": "Good to know.", "next_state": "first_meeting" },
        { "id": "bye",  "text": "Thanks.",       "next_state": "exit" }
      ]
    },

    "specials_info": {
      "introduction": [
        "Stew is hot, bread is fresh, and the ale is cold.",
        "Do not ask what is in the stew unless you really want to know."
      ],
      "options": [
        { "id": "back2", "text": "I will keep that in mind.", "next_state": "first_meeting" },
        { "id": "bye2",  "text": "Maybe later.",            "next_state": "exit" }
      ]
    },

    "knows_about_swamp": {
      "introduction": [
        "There is an old church out in the swamp. ", "Folks say lights move out there at night.",
        "People who go poking around sometimes do not come back."
      ],
      "options": [
        {
          "id": "ask_mayor",
          "text": "Who should I talk to about this?",
          "effects": [
            { "type": "set_flag", "flag": "meredith_mentioned_mayor", "value": true },
            { "type": "set_flag", "flag": "meredith_directed_to_mayor", "value": true }
          ],
          "next_state": "gave_mayor_directions"
        },
        { "id": "more_details", 
        "text": "What have you heard exactly?", 
        "effects": [
          { "type": "set_flag", "flag": "swamp_church_details_known", "value": true }
        ],
        "next_state": "swamp_details" 
        },
        { "id": "bye_warned",   "text": "Thanks for the warning.",      "next_state": "exit" }
      ]
    },

    "swamp_details": {
      "introduction": [
        "Hunters talk about chanting when the wind dies", "and shapes in the fog.",
        "Heard murmurs of Cultist, or something like that",
        "Could be stories. Could be trouble."
      ],
      "options": [
        { "id": "back3", "text": "Alright.", "next_state": "knows_about_swamp" },
        { "id": "bye3",  "text": "I will be careful.", "next_state": "exit" }
      ]
    },

    "gave_mayor_directions": {
      "introduction": [
        "Talk to the Mayor about the disappearances.",
        "If anyone is tracking it, it is him."
      ],
      "options": [
        { "id": "bye", "text": "I will do that.", "next_state": "exit" }
      ]
    },

    "return_visits": {
      "introduction": ["Back again? What can I get you?"],
      "options": [
        { "id": "ask_business", "text": "How is business?", "next_state": "business_smalltalk" },
        {
          "id": "swamp_followup",
          "text": "Any new word about the swamp church?",
          "requirements": { "flags": { "learned_about_swamp_church": true } },
          "next_state": "swamp_update"
        },
        {"id": "ask_tremors",
        "text": "Have you felt the tremors?",
        "effects": [
          {
            "type": "set_flag",
            "flag": "meredith_worried_tremors",
            "value": true
          }
        ],
        "next_state": "tremor_discussion"
        },
        { "id": "bye_casual", "text": "Just saying hello.", "next_state": "exit" }
      ]
    },

    "business_smalltalk": {
      "introduction": [
        "Busy enough. Outsiders passing through, ", "asking the same questions.",
        "You are not the only one curious about the outskirts."
      ],
      "options": [
        { "id": "back4", "text": "Makes sense.", "next_state": "return_visits" },
        { "id": "bye4",  "text": "Take care.",   "next_state": "exit" }
      ]
    },

    "swamp_update": {
      "introduction": [
        "No fresh news—just uneasy looks and quiet voices.",
        "If you learn anything, let me know."
      ],
      "options": [
        { "id": "back5", "text": "Will do.",    "next_state": "return_visits" },
        { "id": "bye5",  "text": "Stay safe.",  "next_state": "exit" }
      ]
    },

    "post_mayor": {
      "introduction": [
        "Heard you spoke with the Mayor. Keep your wits about you if you head toward the marsh."
      ],
      "options": [
        {
          "id": "post_swamp_followup",
          "text": "Any further word about the swamp church?",
          "requirements": { "flags": { "learned_about_swamp_church": true } },
          "next_state": "swamp_update"
        },
        {
          "id": "ring_quest",
          "text": "You seem troubled about something else.",
          "requirements": {
            "flags": {
              "meredith_talked": true,
              "mayor_talked": true} },
          "next_state": "ring_quest_offer"
        },    
        { "id": "bye_post", "text": "Thanks.", "next_state": "exit" }
      ]
    },
    "ring_quest_offer": {
      "introduction": [
        "*Meredith looks worried*",
        "I hate to ask, but... I lost something precious.",
        "My grandmother's silver ring.",
        "*She wrings her hands*",
        "I lost it near the old Red Hollow Mine. Eastern edge of town.",
        "I haven't dared go back there with all the strange noises lately."
      ],
      "options": [
        {
          "id": "accept_ring_quest",
          "text": "I'll look for your ring.",
          "effects": [
            {
              "type": "set_flag",
              "flag": "meredith_gave_ring_quest",
              "value": true
            },
            {
              "type": "set_flag",
              "flag": "meredith_mentioned_old_mine",
              "value": true
            }
          ],
          "next_state": "ring_quest_accepted"
        },
        {
          "id": "ask_about_noises",
          "text": "What kind of strange noises?",
          "next_state": "mine_noises_discussion"
        },
        {
          "id": "decline_ring",
          "text": "I'm sorry, I can't help right now.",
          "next_state": "ring_quest_declined"
        }
      ]
    },

    "mine_noises_discussion": {
      "introduction": [
        "Scratching. Digging sounds from inside the old shafts.",
        "Could be nothing. Could be something moved in.",
        "*She shudders*",
        "Either way, I'm not going near it."
      ],
      "options": [
        {
          "id": "accept_after_hearing",
          "text": "I'll find your ring.",
          "effects": [
            {
              "type": "set_flag",
              "flag": "meredith_gave_ring_quest",
              "value": true
            },
            {
              "type": "set_flag",
              "flag": "meredith_mentioned_old_mine",
              "value": true
            }
          ],
          "next_state": "ring_quest_accepted"
        },
        {
          "id": "too_dangerous",
          "text": "That sounds too dangerous.",
          "next_state": "ring_quest_declined"
        }
      ]
    },

    "ring_quest_accepted": {
      "introduction": [
        "*Meredith's eyes brighten with hope*",
        "Thank you! It means the world to me.",
        "Silver band with a small blue stone. Family heirloom.",
        "Red Hollow Mine, eastern edge of town.",
        "Please be careful."
      ],
      "options": [
        {
          "id": "head_out",
          "text": "I'll find it.",
          "next_state": "exit"
        }
      ]
    },

    "ring_quest_declined": {
      "introduction": [
        "*Meredith nods sadly*",
        "I understand. It's a lot to ask.",
        "If you change your mind, let me know."
      ],
      "options": [
        {
          "id": "maybe_later",
          "text": "Maybe later.",
          "next_state": "exit"
        }
      ]
    },

    "ring_quest_active": {
      "introduction": [
        "Any luck finding my ring?",
        "*She looks hopeful*"
      ],
      "options": [
        {
          "id": "still_looking",
          "text": "Still searching.",
          "next_state": "exit"
        },
        {
          "id": "found_it",
          "text": "I found it! [Give ring]",
          "requirements": {
            "flags": {
              "returned_meredith_ring": true
            }
          },
          "next_state": "ring_returned_thanks"
        }
      ]
    },

    "ring_returned_thanks": {
      "introduction": [
        "*Meredith gasps with joy*",
        "You found it! Oh, thank you!",
        "*She holds the ring carefully*",
        "My grandmother wore this every day of her life.",
        "Here, please take this. It's not much, but you've earned it."
      ],
      "options": [
        {
          "id": "accept_reward",
          "text": "I'm glad I could help.",
          "next_state": "post_mayor"
        }
      ]
    },
    "tremor_discussion": {
      "introduction": [
        "*Meredith's face grows serious*",
        "Yes. They started a few weeks ago.",
        "Getting worse each day.",
        "Glasses fall off shelves. Pictures tilt on the walls.",
        "*She lowers her voice*",
        "Some say it's connected to the old mines."
      ],
      "options": [
        {
          "id": "ask_mines",
          "text": "What about the old mines?",
          "next_state": "mine_connection"
        },
        {
          "id": "worrying",
          "text": "That is worrying.",
          "next_state": "return_visits"
        }
      ]
    },
    "mine_connection": {
      "introduction": [
        "Red Hollow Mine. Used to be the main operation.",
        "They found something strange down there years ago.",
        "*She glances around nervously*",
        "Some kind of glowing ore. Made people... uneasy.",
        "Henrik knows more. He worked those deep veins.",
        "Now he sells vegetables in the town square."
      ],
      "options": [
        {
          "id": "thanks_info",
          "text": "Thanks for the information.",
          "next_state": "return_visits"
        },
        {
          "id": "henrik_question",
          "text": "Henrik? I should talk to him.",
          "next_state": "henrik_suggestion"
        }
      ]
    },
    "henrik_suggestion": {
      "introduction": [
        "He might not want to talk about it.",
        "Came back from somewhere... changed.",
        "But he knows the mines better than anyone."
      ],
      "options": [
        {
          "id": "find_henrik",
          "text": "I'll find him.",
          "next_state": "exit"
        }
      ]
    }
  }
}
