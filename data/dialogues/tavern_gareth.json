{
  "id": "tavern_gareth",
  "npc_id": "gareth",
  "npc_name": "Gareth Ironwill",
  "default_state": "first_meeting",
  "states": {
    "first_meeting": {
      "introduction": [
        "*A grizzled warrior studies you with calculating eyes*",
        "I've been watching you since you arrived.",
        "You have the look of someone who attracts trouble—or seeks it.",
        "In times like these, that could be exactly what's needed."
      ],
      "options": [
                {
          "id": "ask_to_join",
          "text": "What will it take to earn your sword?",
          "response": [
            "I don't take orders from strangers, friend.",
            "You want my sword? Talk to the Mayor first.",
            "He'll vouch for your character, or he won't.",
            "Either way, I'll know where you stand."
          ],
          "actions": ["agree_meet_mayor", "change_subject"]
        },
        {
          "id": "smalltalk",
          "text": "Just checking in.",
          "response": ["Stay sharp. Trouble's near."],
          "actions": ["exit"]
        },

        { 
          "id": "ready_check",
          "text": "Think my party's ready for you?",
          "requirements": { "flags": { "mayor_vouched": true } },
          "response": [
            "So the Mayor has spoken for you. That's enough for me."
          ],
          "actions": ["to_verified"]
        }
      ]
    },

    "mayor_verified": {
      "introduction": [
        "Gareth nods once. 'The Mayor vouches for you. Good enough.'"
      ],
      "options": [
        {
          "id": "recruit_now",
          "text": "Stand with us.",
          "response": [
            "Gareth hefts his axe.",
            "'Twenty years I've fought for causes both noble and questionable.",
            "This feels like the former. I'm with you.'"
          ],
          "actions": ["recruit_gareth", "exit_to_patrons"]
        },
        {
          "id": "not_yet",
          "text": "Not yet.",
          "response": ["I'll be here."],
          "actions": ["exit"]
        }
      ]
    },

    "in_party": {
      "introduction": ["Gareth grunts. 'Lead on.'"],
      "options": [
        {
          "id": "party_banter",
          "text": "Any advice?",
          "response": ["Keep your back to a wall and your blade clean."],
          "actions": ["exit"]
        }
      ]
    }
  },

  "actions": {
    "agree_meet_mayor": {
      "type": "quest_update",
      "quest_id": "main_investigation",
      "step": "talk_to_mayor",
      "text": "Agree To Talk To Mayor"
    },
    "change_subject": {
      "type": "dialogue_branch",
      "target_state": "first_meeting",
      "text": "Change Subject"
    },
    "branch_verified": {
      "type": "dialogue_branch",
      "target_state": "mayor_verified",
      "text": "Proceed"
    },
    "recruit_gareth": {
      "type": "recruit_npc",
      "npc_id": "gareth",
      "text": "Enter In Party"
    
    
    }
  }
}