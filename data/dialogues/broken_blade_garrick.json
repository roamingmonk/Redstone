{
  "id": "broken_blade_garrick",
  "npc_name": "Garrick Ironbrew",
  
  "states": {
    "first_meeting": {
      "introduction": ["Name's Garrick. I run this place.", "Keep it civil and we'll get along fine."],
      "options": [
        {
          "id": "ask_supplies",
          "text": "Do you sell supplies?",
          "next_state": "supplies_info"
        },
        {
          "id": "ask_tavern",
          "text": "Tell me about this tavern.",
          "next_state": "about_tavern"
        },
        {
          "id": "ask_rumors",
          "text": "Any interesting rumors?",
          "effects": [
            {
              "type": "set_flag",
              "flag": "garrick_gave_ruins_info",
              "value": true
            },
            {
              "type": "set_flag",
              "flag": "learned_about_ruins",
              "value": true
            }
          ],
          "next_state": "knows_about_ruins"
        },
        {
          "id": "goodbye_first",
          "text": "Just looking around. Goodbye.",
          "next_state": "exit"
        }
      ]
    },
    
    "about_tavern": {
      "introduction": [
        "Oldest alehouse in town. Built after the first mine strike.",
        "Miners, hunters, and the odd scholar keep the stools warm."
      ],
      "options": [
        { "id": "back_first", "text": "Got it.", "next_state": "first_meeting" },
        { "id": "bye",        "text": "Thanks. Goodbye.", "next_state": "exit" }
      ]
    },

    "supplies_info": {
      "introduction": [
        "I pour drinks mostly, but I do keep some basic supplies for travelers.",
        "Nothing fancy - just the essentials."
      ],
      "options": [
        {
          "id": "browse_supplies",
          "text": "Can I see what you have?",
          "effects": [
            {
              "type": "open_shop",
              "merchant_id": "garrick"
            }
          ],
          "next_state": "post_shopping"
        },
        { "id": "back_first2", "text": "Maybe later.", "next_state": "first_meeting" },
        { "id": "bye2", "text": "Thanks anyway.", "next_state": "exit" }
      ]
    },

    "post_shopping": {
      "introduction": ["Take your time looking around."],
      "options": [
        { "id": "back_to_talk", "text": "Let's talk.", "next_state": "first_meeting" },
        { "id": "goodbye", "text": "Thanks.", "next_state": "exit" }
      ]
    },

    "after_first_talk": {
      "introduction": ["Back again? Need something else?"],
      "options": [
        {
          "id": "ask_supplies_again",
          "text": "About those supplies...",
          "next_state": "supplies_info"
        },
        {
          "id": "ask_rumors_again",
          "text": "Any rumors worth hearing?",
          "effects": [
            {
              "type": "set_flag",
              "flag": "garrick_gave_ruins_info",
              "value": true
            },
            {
              "type": "set_flag",
              "flag": "learned_about_ruins",
              "value": true
            }
          ],
          "next_state": "knows_about_ruins"
        },
        {
          "id": "goodbye_return",
          "text": "Nothing right now.",
          "next_state": "exit"
        }
      ]
    },
    
    "knows_about_ruins": {
      "introduction": ["You heard about those ruins, eh?", "Dangerous place. People go missing up there."],
      "options": [
        {
          "id": "ask_mayor_about_missing",
          "text": "Who should I talk to about this?",
          "effects": [
            {
              "type": "set_flag",
              "flag": "garrick_mentioned_mayor",
              "value": true
            }
          ],
          "next_state": "gave_mayor_directions"
        },
        {
          "id": "ask_more_details",
          "text": "Tell me more about what happened.",
          "next_state": "ruins_details"
        },
        {
          "id": "thanks_info",
          "text": "Thanks for the warning.",
          "next_state": "exit"
        }
      ]
    },
    
    "gave_mayor_directions": {
      "introduction": ["Talk to the Mayor about the disappearances.", "His office is across the square -", "Big building with the town banner.", "Tell him I sent you if you need an introduction."],
      "options": [
        {
          "id": "thank_directions",
          "text": "Thank you for the directions.",
          "next_state": "helpful_conclusion"
        },
        {
          "id": "ask_more_about_ruins",
          "text": "What else can you tell me about the ruins?",
          "next_state": "ruins_details"
        },
        {
          "id": "ready_to_go",
          "text": "I'll head there now.",
          "next_state": "exit"
        }
      ]
    },

    "post_mayor_no_basement": {
      "introduction": ["Heard you spoke with the Mayor.", "About time someone looked into those disappearances."],
      "options": [
        {
          "id": "need_practice",
          "text": "I could use some practice first.",
          "effects": [
            {
              "type": "set_flag",
              "flag": "garrick_offered_basement",
              "value": true
            }
          ],
          "next_state": "post_mayor_basement_offered"
        },
        {
          "id": "ready_to_go",
          "text": "I'm ready for whatever's out there.",
          "next_state": "exit"
        },
        {
          "id": "ask_more_about_ruins",
          "text": "What else can you tell me about the ruins?",
          "next_state": "ruins_details"
        }
      ]
    },
    
    "post_mayor_basement_offered": {
      "introduction": ["Got a rat problem in the basement if you want practice.", "Big rats. Clear them out for some coin?"],
      "options": [
        {
          "id": "accept_basement",
          "text": "I'll handle your rat problem.",
          "effects": [
            {
              "type": "set_flag",
              "flag": "accepted_basement_quest",
              "value": true
            }
          ],
          "next_state": "post_mayor_basement_accepted"
        },
        {
          "id": "maybe_later",
          "text": "Maybe later.",
          "next_state": "exit"
        }
      ]
    },
    
    "post_mayor_basement_accepted": {
      "introduction": ["Thanks for helping! The basement1 is behind the bar.", "Watch yourself down there - they're meaner than normal rats.", "Come back when you're done and I'll settle up."],
      "options": [
        {
          "id": "head_down_now",
          "text": "I'll take care of it right now.",
          "next_state": "exit"
        },
        {
          "id": "prepare_first",
          "text": "Let me prepare first.",
          "next_state": "supplies_info"
        }
      ]
    },

    "post_mayor_basement_complete": {
      "introduction": [
        "Well done! Those rats were getting out of hand.",
        "Here's your payment as promised.",
        "You're ready for bigger challenges now."
      ],
      "options": [
        {
          "id": "take_payment",
          "text": "Thanks for the work.",
          "effects": [
            { "type": "set_flag", "flag": "reported_basement_victory", "value": true },
            { "type": "set_flag", "flag": "garrick_paid", "value": true }
          ],
          "next_state": "post_payment_idle"
        },
        {
          "id": "ask_ruins_after_job",
          "text": "Now about those ruins…",
          "effects": [
            { "type": "set_flag", "flag": "reported_basement_victory", "value": true }
          ],
          "next_state": "knows_about_ruins"
        }
      ]
    },

    "post_payment_idle": {
      "introduction": ["Your tab is settled. Grab a stool anytime."],
      "options": [
        { 
          "id": "bye", 
          "text": "Later.", 
          "effects": [{ "type": "set_flag", "flag": "post_payment_acknowledged", "value": true }],
          "next_state": "exit" }]
    },
    
    "ruins_details": {
      "introduction": ["The ruins are old - older than the town.", "Strange carvings on the stones,","symbols nobody can read.", "The few who came back... ", "they won't talk about what they saw."],
      "options": [
        {
          "id": "ask_about_survivors",
          "text": "Who came back? Can I talk to them?",
          "next_state": "survivor_info"
        },
        {
          "id": "ask_about_symbols",
          "text": "What kind of symbols?",
          "next_state": "symbol_description"
        },
        {
          "id": "enough_details",
          "text": "That's enough for now.",
          "next_state": "exit"
        }
      ]
    },
    
    "survivor_info": {
      "introduction": ["Old Henrik made it back, but he's... different now.", "Sits in the corner most days,","staring at nothing.", "Won't say a word about what he saw up there."],
      "options": [
        {
          "id": "where_is_henrik",
          "text": "Where can I find Henrik?",
          "next_state": "henrik_location"
        },
        {
          "id": "anyone_else",
          "text": "Anyone else make it back?",
          "next_state": "other_survivors"
        },
        {
          "id": "understood",
          "text": "I understand.",
          "next_state": "exit"
        }
      ]
    },
    
    "henrik_location": {
      "introduction": ["Henrik's usually at the market during the day.", "Sells what few vegetables his hands can still tend.", "But like I said,","he won't talk about the ruins."],
      "options": [
        {
          "id": "ill_try",
          "text": "I'll try talking to him anyway.",
          "next_state": "exit"
        },
        {
          "id": "good_to_know",
          "text": "Good to know. Thanks.",
          "next_state": "exit"
        }
      ]
    },

    "other_survivors": {
      "introduction": ["A few others made it back over the years.", "Most won't talk about it.", "Those that do... well,", "their stories don't match."],
      "options": [
        {
          "id": "conflicting_stories",
          "text": "What do you mean they don't match?",
          "next_state": "conflicting_accounts"
        },
        {
          "id": "enough_survivors",
          "text": "I've heard enough.",
          "next_state": "exit"
        }
      ]
    },

    "conflicting_accounts": {
      "introduction": ["Some say they saw lights in the darkness.", "Others swear the stones moved on their own.", "One fellow claimed he heard voices", "... calling his name."],
      "options": [
        {
          "id": "voices_detail",
          "text": "Voices calling his name?",
          "next_state": "voice_mystery"
        },
        {
          "id": "moving_stones",
          "text": "Moving stones?",
          "next_state": "stone_mystery"
        },
        {
          "id": "too_strange",
          "text": "That's... unsettling.",
          "next_state": "exit"
        }
      ]
    },

    "voice_mystery": {
      "introduction": ["Poor Aldric.", "Swore something was calling to him from deep below.", "Said it knew things about him no one else could know.", "Haven't seen him since he tried to go back."],
      "options": [
        {
          "id": "went_back",
          "text": "He went back?",
          "next_state": "aldric_fate"
        },
        {
          "id": "disturbing",
          "text": "That's deeply disturbing.",
          "next_state": "exit"
        }
      ]
    },

    "aldric_fate": {
      "introduction": ["Three months ago. ", "Said he had to know what was calling him.", "We organized a search party after a week.", "Found his torch at the entrance.", "Nothing else."],
      "options": [
        {
          "id": "recent_disappearance",
          "text": "So recent disappearances are still happening.",
          "next_state": "ongoing_danger"
        },
        {
          "id": "poor_aldric",
          "text": "Poor man.",
          "next_state": "exit"
        }
      ]
    },

    "ongoing_danger": {
      "introduction": ["Aye. Mayor's been trying to organize something.", "But most folk are too scared.", "Can't say I blame them."],
      "options": [
        {
          "id": "mayor_plans",
          "text": "What kind of organization?",
          "next_state": "mayor_efforts"
        },
        {
          "id": "understand_fear",
          "text": "I understand their fear.",
          "next_state": "exit"
        }
      ]
    },

    "mayor_efforts": {
      "introduction": ["Talk to him yourself. ", "He's got ideas about hiring proper adventurers.", "Folk with experience dealing with", "... unusual problems.", "That's all I know."],
      "options": [
        {
          "id": "thank_info",
          "text": "Thanks for the information.",
          "next_state": "exit"
        }
      ]
    },
    
    "symbol_description": {
      "introduction": ["Spirals and sharp angles, ", "carved deep into the stone.", "Some say they're just old tribal markings.", "Others think they're something... else."],
      "options": [
        {
          "id": "what_else",
          "text": "What do others think they are?",
          "next_state": "symbol_theories"
        },
        {
          "id": "interesting",
          "text": "Interesting. I'll keep that in mind.",
          "next_state": "exit"
        }
      ]
    },
    
    "symbol_theories": {
      "introduction": ["Some of the older folk whisper about dark magic.", "Others say they're warnings,", "left by whoever built the place.", "All I know is they give me the shivers."],
      "options": [
        {
          "id": "dark_magic",
          "text": "Dark magic? You believe that?",
          "next_state": "magic_opinion"
        },
        {
          "id": "warnings",
          "text": "Warnings about what?",
          "next_state": "warning_speculation"
        },
        {
          "id": "enough_theories",
          "text": "Thanks for the information.",
          "next_state": "exit"
        }
      ]
    },

    "magic_opinion": {
      "introduction": ["I've seen enough strange things in my years.", "Magic's real, whether folk want to believe it or not.", "The question is what kind of magic", "made those symbols."],
      "options": [
        {
          "id": "what_kind",
          "text": "What kind do you think it is?",
          "next_state": "dark_magic_theory"
        },
        {
          "id": "agree_magic_real",
          "text": "I agree magic is real.",
          "next_state": "exit"
        }
      ]
    },

    "dark_magic_theory": {
      "introduction": ["The kind that hungers. ", "That calls to people.", "The kind that doesn't let go once it has hold of you.", "Stay away from those ruins,", "if you're smart."],
      "options": [
        {
          "id": "final_warning",
          "text": "I'll be careful.",
          "next_state": "exit"
        }
      ]
    },

    "warning_speculation": {
      "introduction": ["Warnings to stay away, maybe.", "Or warnings about what's buried there.", "Either way, they didn't work - people keep going."],
      "options": [
        {
          "id": "what_buried",
          "text": "What do you think is buried there?",
          "next_state": "burial_theory"
        },
        {
          "id": "warnings_ignored",
          "text": "People ignore warnings when they're desperate.",
          "next_state": "exit"
        }
      ]
    },

    "burial_theory": {
      "introduction": ["Something old. Something that should have stayed buried.", "The ruins are just the surface. There's more underneath.", "Much more."],
      "options": [
        {
          "id": "underground_structures",
          "text": "Underground structures?",
          "next_state": "underground_details"
        },
        {
          "id": "ominous_enough",
          "text": "That's ominous enough for me.",
          "next_state": "exit"
        }
      ]
    },

    "underground_details": {
      "introduction": ["Tunnels. Chambers. ", "Things carved from living rock.", "The few who've been down there and lived...", "they won't describe it.", "They can't. The words won't come."],
      "options": [
        {
          "id": "cant_describe",
          "text": "They can't describe it?",
          "next_state": "description_curse"
        },
        {
          "id": "enough_details_final",
          "text": "I think I've heard enough.",
          "next_state": "exit"
        }
      ]
    },

    "description_curse": {
      "introduction": ["Try to ask them and they just...", "stop talking.", "Look at you with empty eyes.", "Like something took the words right out of their heads."],
      "options": [
        {
          "id": "truly_final",
          "text": "That's truly unsettling.",
          "next_state": "exit"
        }
      ]
    },
    
    "casual_chat": {
      "introduction": ["Back for another drink? What brings you by?"],
      "options": [
        {
          "id": "ask_supplies_casual",
          "text": "Do you sell any supplies?",
          "next_state": "supplies_info"
        },
        {
          "id": "check_basement_quest",
          "text": "About that basement job...",
          "requirements": { "flags": { "garrick_offered_basement": true } },
          "next_state": "basement_quest_status"
        },
        {
          "id": "ruins_small_talk",
          "text": "Any word on the ruins situation?",
          "requirements": { "flags": { "learned_about_ruins": true } },
          "next_state": "knows_about_ruins"
        },
        {
          "id": "goodbye_casual",
          "text": "Just saying hello.",
          "next_state": "exit"
        }
      ]
    },
    
    "helpful_conclusion": {
      "introduction": ["Glad I could help. Be careful up there."],
      "options": [
        {
          "id": "will_be_careful",
          "text": "I will. Thanks again.",
          "next_state": "exit"
        }
      ]
    }
  }
}