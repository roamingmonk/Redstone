  "dialogue_state_mapping": {
    "_comment0": "//// Determines dialoguge entry point based on states known. order is very important///", 
    "_comment1": "//// as the first true item is what is selected.  /////////////////////////////////////",
    "_comment2": "//// Only levels or key entry points, not all dialogue states should be used.  ////////",
    "_comment3": "////  Note:  ! = false,  && = AND ,  || = OR //////////////////////////////////////////",
    
    "meredith": {
      "first_meeting": "!meredith_talked",
      "meredith_after_casper_returned_ring": "casper_returned_ring_to_meredith && meredith_talked",
      "ring_returned_thanks": "returned_meredith_ring && !casper_returned_ring_to_meredith",
      "ring_quest_active": "meredith_gave_ring_quest && !returned_meredith_ring && !casper_returned_ring_to_meredith",
      "ring_quest_offer": "meredith_talked && mayor_talked && !meredith_gave_ring_quest && !returned_meredith_ring && !casper_returned_ring_to_meredith",
      "knows_about_swamp": "meredith_talked && !mayor_talked && learned_about_swamp_church",
      "post_mayor": "meredith_talked && mayor_talked",
      "return_visits": "meredith_talked && !mayor_talked"
    },
    "beggar": {
      "first_meeting": "!beggar_talked",
      "redemption_pending": "casper_given_ring && !casper_disappeared",
      "return_visits_with_ring": "casper_ring_mentioned && found_merediths_ring && !casper_given_ring && !casper_declined_redemption",
      "return_visits": "beggar_talked"
    },
    "casper_and_meredith_epilogue": {
      "first_meeting": "!epilogue_couple_talked",
      "return_visit": "epilogue_couple_talked"
    },
    "garrick": {
      "first_meeting": "!garrick_talked",
      "casual_chat": "(garrick_talked && garrick_mentioned_mayor && !mayor_talked) || (garrick_talked && mayor_talked && reported_basement_victory && post_payment_acknowledged)",
      "knows_about_ruins": "garrick_talked && !mayor_talked && learned_about_ruins",
      "after_first_talk": "garrick_talked && !mayor_talked && !learned_about_ruins",
      "post_payment_idle": "garrick_talked && mayor_talked && completed_basement_combat && reported_basement_victory && !post_payment_acknowledged",
      "post_mayor_basement_complete": "garrick_talked && mayor_talked && completed_basement_combat",
      "post_mayor_basement_accepted": "garrick_talked && mayor_talked && accepted_basement_quest && !completed_basement_combat",
      "post_mayor_basement_offered": "garrick_talked && mayor_talked && garrick_offered_basement && !accepted_basement_quest",
      "post_mayor_no_basement": "garrick_talked && mayor_talked && !garrick_offered_basement"
    },
    "pete": {
      "first_meeting": "!pete_talked",
      "comedy_sequence": "pete_attempted_recruitment && !pete_comedy_complete",
      "post_info_comedy": "pete_comedy_complete && pete_gave_refugee_info",
      "post_comedy": "pete_comedy_complete && !pete_gave_refugee_info",
      "pre_recruitment_comedy": "pete_talked && !pete_attempted_recruitment"
    },
   "mayor": {
      "_comment_act2": "=== ACT II OFFICE STATES (redstone_town_mayor.json) - Most specific first ===",
      
      "swamp_complete_first_time": "act_two_started && swamp_church_complete && !mayor_acknowledged_swamp_complete",
      "ruins_complete_first_time": "act_two_started && hill_ruins_complete && !mayor_acknowledged_ruins_complete",
      "refugee_complete_first_time": "act_two_started && refugee_camp_complete && !mayor_acknowledged_refugee_complete",
      "mine_complete_first_time": "act_two_started && red_hollow_mine_complete && !mayor_acknowledged_mine_complete",
      "ready_for_act_three": "act_two_started && swamp_church_complete && hill_ruins_complete && refugee_camp_complete && mayor_acknowledged_swamp_complete && mayor_acknowledged_ruins_complete && mayor_acknowledged_refugee_complete",
      "multiple_progress": "act_two_started && (mayor_acknowledged_swamp_complete || mayor_acknowledged_ruins_complete || mayor_acknowledged_refugee_complete || mayor_acknowledged_mine_complete)",
      "no_progress": "act_two_started && mayor_talked",
      
      "_comment_act1": "=== ACT I TAVERN STATES (patron_selection_mayor.json) ===",
      "first_meeting": "!mayor_talked && !act_two_started",
      "post_completion_reward": "!act_two_started && quest_active && main_quest_completed && !reported_main_quest",
      "ore_sample_discussion": "!act_two_started && reported_main_quest && retrieved_ore_samples && !mayor_examined_ore_samples",
      "post_completion_idle": "!act_two_started && quest_active && main_quest_completed && reported_main_quest",
      "quest_given": "!act_two_started && quest_active && !main_quest_completed && !(learned_about_swamp_church || learned_about_ruins || learned_about_refugees)",
      "progress_updates": "!act_two_started && mayor_talked && quest_active && (learned_about_swamp_church || learned_about_ruins || learned_about_refugees) && !main_quest_completed",

      "_comment_fallback": "=== FALLBACK - Office closed before Act II ===",
      "office_closed": "!act_two_started"
    },
    "gareth": {
      "first_meeting_post_mayor": "!gareth_talked && mayor_talked",
      "first_meeting": "!gareth_talked",
      "already_recruited": "gareth_recruited",
      "recruitment_blocked": "gareth_talked && mayor_talked && !gareth_recruited && recruited_count >= 3",
      "recruitment_available": "gareth_talked && mayor_talked && !gareth_recruited && recruited_count < 3",
      "casual_chat": "gareth_talked && !mayor_talked"
    },
    "elara": {
      "first_meeting_post_mayor": "!elara_talked && mayor_talked",
      "first_meeting": "!elara_talked", 
      "already_recruited": "elara_recruited",
      "recruitment_blocked": "elara_talked && mayor_talked && !elara_recruited && recruited_count >= 3",
      "recruitment_available": "elara_talked && mayor_talked && !elara_recruited && recruited_count < 3",
      "casual_chat": "elara_talked && !mayor_talked"
