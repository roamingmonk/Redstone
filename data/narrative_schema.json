        "learn_refugee_camp": ["pete_gave_refugee_info"],
        
        "explore_swamp_church": ["learned_about_swamp_church", "explored_swamp_church"],
        "explore_hill_ruins": ["learned_about_ruins", "explored_hill_ruins"],
