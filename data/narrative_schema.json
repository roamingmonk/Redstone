  "quest_mappings": {
    "main_story": {
      "type": "primary",
      "objectives": {
        "talk_to_npcs": ["meredith_talked", "garrick_talked"],
        "meet_mayor": ["mayor_talked"],
        "recruit_party": ["recruited_count >= 1"],
        "investigate_swamp_church": ["learned_about_swamp_church", "explored_swamp_church"],
        "investigate_hill_ruins": ["learned_about_ruins", "explored_hill_ruins"],
        "investigate_refugee_camp": ["learned_about_refugees", "gathered_refugee_info"],
        "solve_mystery": ["found_swamp_evidence", "found_ruins_evidence", "gathered_refugee_info"]
      }
    },
    "party_building": {
      "type": "secondary",
      "activation_flag": "mayor_talked",
      "objectives": {
        "recruit_warrior": ["gareth_recruited"],
        "recruit_mage": ["elara_recruited"], 
        "recruit_cleric": ["thorman_recruited"],
        "recruit_rogue": ["lyra_recruited"]
      }
    },
    "basement_rat_combat": {
      "type": "secondary",
      "activation_flag": "garrick_offered_basement",
      "objectives": {
        "accept_challenge": ["accepted_basement_quest"],
        "clear_basement": ["completed_basement_combat"],
        "report_success": ["reported_basement_victory"]
      }
    }
  },

