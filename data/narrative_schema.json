      "recruitment_available": "gareth_talked && !gareth_recruited && mayor_talked && recruited_count < 3",
      "recruitment_blocked": "gareth_talked && recruited_count >= 3",
      "already_recruited": "gareth_recruited",
      "casual_chat": "gareth_talked && !mayor_talked"
    },
    "elara": {
      "first_meeting": "!elara_talked", 
